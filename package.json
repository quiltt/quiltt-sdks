{
  "name": "@quiltt/quiltt-sdks",
  "version": "1.0.0",
  "description": "Quiltt's Open Source Projects",
  "license": "MIT",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "prebuild": "[ \"$CI\" = \"true\" ] && pnpm install --store=node_modules/.pnpm-store || echo skipping pnpm install; turbo run prebuild",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "bundlesize": "bundlesize",
    "changeset": "npx changeset",
    "check:packages": "pnpm check-dependency-version-consistency .",
    "clean": "turbo run clean",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "publish": "pnpm run build:packages && npx changeset tag && pnpm -r publish --no-git-checks --filter=./packages/**",
    "test": "turbo run test",
    "test:unit": "vitest run --coverage",
    "test:e2e": "turbo run test:component",
    "typecheck": "turbo run typecheck",
    "version": "npx changeset version",
    "postversion": "pnpm exec pnpm install --filter=./packages/** "
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-native": "13.3.3",
    "@types/node": "24.12.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-istanbul": "4.1.0",
    "bundlesize": "0.18.2",
    "check-dependency-version-consistency": "6.0.0",
    "happy-dom": "20.8.4",
    "turbo": "2.8.17",
    "vite": "8.0.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0",
    "vitest-react-native": "0.1.5"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "detox",
      "dtrace-provider",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "iltorb": "npm:noop2@^2.0.0",
      "undici@<=7.24.1": "7.24.1"
    }
  },
  "bundlesize": [
    {
      "path": "./packages/core/dist/index.js",
      "maxSize": "5 kB",
      "compression": "gzip"
    },
    {
      "path": "./packages/react/dist/index.js",
      "maxSize": "10 kB",
      "compression": "gzip"
    },
    {
      "path": "./packages/react-native/dist/index.js",
      "maxSize": "10 kB",
      "compression": "gzip"
    }
  ]
}
